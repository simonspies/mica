(set-option :print-success true)

;; preamble
(set-logic ALL)
(set-option :timeout 10000)
(set-option :smt.qi.eager_threshold 5.0)
(set-option :smt.mbqi false)

(declare-sort Other 0)
(declare-sort Loc 0)
(declare-sort Vec 0)
(declare-datatypes ((Value 0) (ValueList 0)) (
  ((of_int (to_int Int))
   (of_bool (to_bool Bool))
   (of_char (to_char (_ BitVec 8)))
   (of_string (to_string (Seq (_ BitVec 8))))
   (of_float (to_float (_ FloatingPoint 11 53)))
   (of_loc (to_loc Loc))
   (of_other (to_other Other))
   (of_tuple (to_tuple ValueList))
   (of_vec (to_vec Vec))
   (of_inj (tag_of Int) (arity_of Int) (payload_of Value)))
  ((vnil)
   (vcons (vhd Value) (vtl ValueList)))
))
(declare-const unit_val Other)

;; A `Value` constructor would need to expose both length and location
(declare-fun array_length (Value) Int)

;; Vector theory. Vectors are exposed as arrays to Z3, and via
;; the uninterpreted functions vec_get, ... to Mica
(declare-fun vec_to_array (Vec) (Array Int Value))
(declare-fun vec_of_array ((Array Int Value) Int) Vec)
(declare-fun vec_length (Vec) Int)
(assert (forall ((w Vec)) (! (<= 0 (vec_length w)) :pattern ((vec_length w)))))

(assert (forall ((w Vec))
  (! (= (vec_of_array (vec_to_array w) (vec_length w)) w)
     :pattern ((vec_to_array w)))))
(assert (forall ((a (Array Int Value)) (n Int))
  (! (=> (<= 0 n) (= (vec_length (vec_of_array a n)) n))
     :pattern ((vec_of_array a n)))))
(assert (forall ((a (Array Int Value)) (n Int) (i Int))
  (! (=> (and (<= 0 i) (< i n))
         (= (select (vec_to_array (vec_of_array a n)) i) (select a i)))
     :pattern ((select (vec_to_array (vec_of_array a n)) i)))))

(declare-fun vec_get (Vec Int) Value)
(declare-fun vec_set (Vec Int Value) Vec)
(declare-fun vec_make (Int Value) Vec)
(assert (forall ((w Vec) (i Int))
  (! (=> (and (<= 0 i) (< i (vec_length w)))
         (= (vec_get w i) (select (vec_to_array w) i)))
     :pattern ((vec_get w i)))))
(assert (forall ((w Vec) (i Int) (x Value))
  (! (=> (and (<= 0 i) (< i (vec_length w)))
         (= (vec_set w i x)
            (vec_of_array (store (vec_to_array w) i x) (vec_length w))))
     :pattern ((vec_set w i x)))))
(assert (forall ((n Int) (x Value))
  (! (=> (<= 0 n)
         (= (vec_make n x) (vec_of_array ((as const (Array Int Value)) x) n)))
     :pattern ((vec_make n x)))))

;; verification
(declare-const guard! Bool)
(declare-fun val_vec_make (Value Value) Value)
(declare-fun val_vec_set (Value Value Value) Value)
(declare-fun val_vec_get (Value Value) Value)
(declare-fun val_vec_length (Value) Value)
(declare-fun fun_id (Value) Value)
(declare-const float_neg_infinity Value)
(declare-const float_infinity Value)
(declare-const float_nan Value)
(declare-fun float_le (Value Value) Value)
(declare-fun float_lt (Value Value) Value)
(declare-fun float_equal (Value Value) Value)
(declare-fun float_max (Value Value) Value)
(declare-fun float_min (Value Value) Value)
(declare-fun float_div (Value Value) Value)
(declare-fun float_mul (Value Value) Value)
(declare-fun float_sub (Value Value) Value)
(declare-fun float_add (Value Value) Value)
(declare-fun float_of_int (Value) Value)
(declare-fun float_is_finite (Value) Value)
(declare-fun float_is_nan (Value) Value)
(declare-fun float_sqrt (Value) Value)
(declare-fun float_neg (Value) Value)
(declare-fun float_abs (Value) Value)
(declare-fun string_ends_with (Value Value) Value)
(declare-fun string_starts_with (Value Value) Value)
(declare-fun string_equal (Value Value) Value)
(declare-fun string_sub (Value Value Value) Value)
(declare-fun string_get (Value Value) Value)
(declare-fun string_cat (Value Value) Value)
(declare-fun string_length (Value) Value)
(declare-fun char_equal (Value Value) Value)
(declare-fun char_chr (Value) Value)
(declare-fun char_code (Value) Value)
(declare-fun int_max (Value Value) Value)
(declare-fun int_min (Value Value) Value)
(assert (forall ((n Value)) (forall ((x Value)) (! (=> (= guard! true) (= (val_vec_make n x) (of_vec (vec_make (to_int n) x)))) :pattern ((val_vec_make n x))))))
(assert (forall ((a Value)) (forall ((b Value)) (! (=> (= guard! true) (is-of_vec (val_vec_make a b))) :pattern ((val_vec_make a b))))))
(assert (forall ((v Value)) (forall ((i Value)) (forall ((x Value)) (! (=> (= guard! true) (= (val_vec_set v i x) (of_vec (vec_set (to_vec v) (to_int i) x)))) :pattern ((val_vec_set v i x)))))))
(assert (forall ((a Value)) (forall ((b Value)) (forall ((c Value)) (! (=> (= guard! true) (is-of_vec (val_vec_set a b c))) :pattern ((val_vec_set a b c)))))))
(assert (forall ((v Value)) (forall ((i Value)) (! (=> (= guard! true) (= (val_vec_get v i) (vec_get (to_vec v) (to_int i)))) :pattern ((val_vec_get v i))))))
(assert (forall ((v Value)) (! (=> (= guard! true) (= (to_int (val_vec_length v)) (vec_length (to_vec v)))) :pattern ((val_vec_length v)))))
(assert (forall ((a Value)) (! (=> (= guard! true) (is-of_int (val_vec_length a))) :pattern ((val_vec_length a)))))
(assert (forall ((x Value)) (! (=> (= guard! true) (= (fun_id x) x)) :pattern ((fun_id x)))))
(assert (= (to_float float_neg_infinity) (_ -oo 11 53)))
(assert (is-of_float float_neg_infinity))
(assert (= (to_float float_infinity) (_ +oo 11 53)))
(assert (is-of_float float_infinity))
(assert (= (to_float float_nan) (_ NaN 11 53)))
(assert (is-of_float float_nan))
(assert (forall ((a Value)) (forall ((b Value)) (! (=> (= guard! true) (= (to_bool (float_le a b)) (fp.leq (to_float a) (to_float b)))) :pattern ((float_le a b))))))
(assert (forall ((a Value)) (forall ((b Value)) (! (=> (= guard! true) (is-of_bool (float_le a b))) :pattern ((float_le a b))))))
(assert (forall ((a Value)) (forall ((b Value)) (! (=> (= guard! true) (= (to_bool (float_lt a b)) (fp.lt (to_float a) (to_float b)))) :pattern ((float_lt a b))))))
(assert (forall ((a Value)) (forall ((b Value)) (! (=> (= guard! true) (is-of_bool (float_lt a b))) :pattern ((float_lt a b))))))
(assert (forall ((a Value)) (forall ((b Value)) (! (=> (= guard! true) (= (to_bool (float_equal a b)) (fp.eq (to_float a) (to_float b)))) :pattern ((float_equal a b))))))
(assert (forall ((a Value)) (forall ((b Value)) (! (=> (= guard! true) (is-of_bool (float_equal a b))) :pattern ((float_equal a b))))))
(assert (forall ((a Value)) (forall ((b Value)) (! (=> (= guard! true) (= (to_float (float_max a b)) (ite (fp.isNaN (to_float a)) (_ NaN 11 53) (ite (fp.isNaN (to_float b)) (_ NaN 11 53) (ite (fp.lt (to_float a) (to_float b)) (to_float b) (ite (fp.lt (to_float b) (to_float a)) (to_float a) (ite (fp.isNegative (to_float a)) (to_float b) (to_float a)))))))) :pattern ((float_max a b))))))
(assert (forall ((a Value)) (forall ((b Value)) (! (=> (= guard! true) (is-of_float (float_max a b))) :pattern ((float_max a b))))))
(assert (forall ((a Value)) (forall ((b Value)) (! (=> (= guard! true) (= (to_float (float_min a b)) (ite (fp.isNaN (to_float a)) (_ NaN 11 53) (ite (fp.isNaN (to_float b)) (_ NaN 11 53) (ite (fp.lt (to_float a) (to_float b)) (to_float a) (ite (fp.lt (to_float b) (to_float a)) (to_float b) (ite (fp.isNegative (to_float a)) (to_float a) (to_float b)))))))) :pattern ((float_min a b))))))
(assert (forall ((a Value)) (forall ((b Value)) (! (=> (= guard! true) (is-of_float (float_min a b))) :pattern ((float_min a b))))))
(assert (forall ((a Value)) (forall ((b Value)) (! (=> (= guard! true) (= (to_float (float_div a b)) (fp.div roundNearestTiesToEven (to_float a) (to_float b)))) :pattern ((float_div a b))))))
(assert (forall ((a Value)) (forall ((b Value)) (! (=> (= guard! true) (is-of_float (float_div a b))) :pattern ((float_div a b))))))
(assert (forall ((a Value)) (forall ((b Value)) (! (=> (= guard! true) (= (to_float (float_mul a b)) (fp.mul roundNearestTiesToEven (to_float a) (to_float b)))) :pattern ((float_mul a b))))))
(assert (forall ((a Value)) (forall ((b Value)) (! (=> (= guard! true) (is-of_float (float_mul a b))) :pattern ((float_mul a b))))))
(assert (forall ((a Value)) (forall ((b Value)) (! (=> (= guard! true) (= (to_float (float_sub a b)) (fp.sub roundNearestTiesToEven (to_float a) (to_float b)))) :pattern ((float_sub a b))))))
(assert (forall ((a Value)) (forall ((b Value)) (! (=> (= guard! true) (is-of_float (float_sub a b))) :pattern ((float_sub a b))))))
(assert (forall ((a Value)) (forall ((b Value)) (! (=> (= guard! true) (= (to_float (float_add a b)) (fp.add roundNearestTiesToEven (to_float a) (to_float b)))) :pattern ((float_add a b))))))
(assert (forall ((a Value)) (forall ((b Value)) (! (=> (= guard! true) (is-of_float (float_add a b))) :pattern ((float_add a b))))))
(assert (forall ((a Value)) (! (=> (= guard! true) (= (to_float (float_of_int a)) ((_ to_fp 11 53) roundNearestTiesToEven (to_int a)))) :pattern ((float_of_int a)))))
(assert (forall ((a Value)) (! (=> (= guard! true) (is-of_float (float_of_int a))) :pattern ((float_of_int a)))))
(assert (forall ((a Value)) (! (=> (= guard! true) (= (to_bool (float_is_finite a)) (ite (fp.isInfinite (to_float a)) false (ite (fp.isNaN (to_float a)) false true)))) :pattern ((float_is_finite a)))))
(assert (forall ((a Value)) (! (=> (= guard! true) (is-of_bool (float_is_finite a))) :pattern ((float_is_finite a)))))
(assert (forall ((a Value)) (! (=> (= guard! true) (= (to_bool (float_is_nan a)) (fp.isNaN (to_float a)))) :pattern ((float_is_nan a)))))
(assert (forall ((a Value)) (! (=> (= guard! true) (is-of_bool (float_is_nan a))) :pattern ((float_is_nan a)))))
(assert (forall ((a Value)) (! (=> (= guard! true) (= (to_float (float_sqrt a)) (fp.sqrt roundNearestTiesToEven (to_float a)))) :pattern ((float_sqrt a)))))
(assert (forall ((a Value)) (! (=> (= guard! true) (is-of_float (float_sqrt a))) :pattern ((float_sqrt a)))))
(assert (forall ((a Value)) (! (=> (= guard! true) (= (to_float (float_neg a)) (fp.neg (to_float a)))) :pattern ((float_neg a)))))
(assert (forall ((a Value)) (! (=> (= guard! true) (is-of_float (float_neg a))) :pattern ((float_neg a)))))
(assert (forall ((a Value)) (! (=> (= guard! true) (= (to_float (float_abs a)) (fp.abs (to_float a)))) :pattern ((float_abs a)))))
(assert (forall ((a Value)) (! (=> (= guard! true) (is-of_float (float_abs a))) :pattern ((float_abs a)))))
(assert (forall ((suffix Value)) (forall ((s Value)) (! (=> (= guard! true) (= (to_bool (string_ends_with suffix s)) (seq.suffixof (to_string suffix) (to_string s)))) :pattern ((string_ends_with suffix s))))))
(assert (forall ((a Value)) (forall ((b Value)) (! (=> (= guard! true) (is-of_bool (string_ends_with a b))) :pattern ((string_ends_with a b))))))
(assert (forall ((prefix Value)) (forall ((s Value)) (! (=> (= guard! true) (= (to_bool (string_starts_with prefix s)) (seq.prefixof (to_string prefix) (to_string s)))) :pattern ((string_starts_with prefix s))))))
(assert (forall ((a Value)) (forall ((b Value)) (! (=> (= guard! true) (is-of_bool (string_starts_with a b))) :pattern ((string_starts_with a b))))))
(assert (forall ((a Value)) (forall ((b Value)) (! (=> (= guard! true) (= (to_bool (string_equal a b)) (= (to_string a) (to_string b)))) :pattern ((string_equal a b))))))
(assert (forall ((a Value)) (forall ((b Value)) (! (=> (= guard! true) (is-of_bool (string_equal a b))) :pattern ((string_equal a b))))))
(assert (forall ((s Value)) (forall ((pos Value)) (forall ((len Value)) (! (=> (= guard! true) (=> (and (<= 0 (to_int pos)) (and (<= 0 (to_int len)) (<= (+ (to_int pos) (to_int len)) (seq.len (to_string s))))) (= (to_string (string_sub s pos len)) (seq.extract (to_string s) (to_int pos) (to_int len))))) :pattern ((string_sub s pos len)))))))
(assert (forall ((a Value)) (forall ((b Value)) (forall ((c Value)) (! (=> (= guard! true) (is-of_string (string_sub a b c))) :pattern ((string_sub a b c)))))))
(assert (forall ((s Value)) (forall ((i Value)) (! (=> (= guard! true) (=> (and (<= 0 (to_int i)) (< (to_int i) (seq.len (to_string s)))) (= (to_char (string_get s i)) (seq.nth (to_string s) (to_int i))))) :pattern ((string_get s i))))))
(assert (forall ((a Value)) (forall ((b Value)) (! (=> (= guard! true) (is-of_char (string_get a b))) :pattern ((string_get a b))))))
(assert (forall ((a Value)) (forall ((b Value)) (! (=> (= guard! true) (= (to_string (string_cat a b)) (seq.++ (to_string a) (to_string b)))) :pattern ((string_cat a b))))))
(assert (forall ((a Value)) (forall ((b Value)) (! (=> (= guard! true) (is-of_string (string_cat a b))) :pattern ((string_cat a b))))))
(assert (forall ((s Value)) (! (=> (= guard! true) (= (to_int (string_length s)) (seq.len (to_string s)))) :pattern ((string_length s)))))
(assert (forall ((a Value)) (! (=> (= guard! true) (is-of_int (string_length a))) :pattern ((string_length a)))))
(assert (forall ((a Value)) (forall ((b Value)) (! (=> (= guard! true) (= (to_bool (char_equal a b)) (= (to_char a) (to_char b)))) :pattern ((char_equal a b))))))
(assert (forall ((a Value)) (forall ((b Value)) (! (=> (= guard! true) (is-of_bool (char_equal a b))) :pattern ((char_equal a b))))))
(assert (forall ((n Value)) (! (=> (= guard! true) (=> (and (<= 0 (to_int n)) (< (to_int n) 256)) (= (to_char (char_chr n)) ((_ int2bv 8) (to_int n))))) :pattern ((char_chr n)))))
(assert (forall ((a Value)) (! (=> (= guard! true) (is-of_char (char_chr a))) :pattern ((char_chr a)))))
(assert (forall ((c Value)) (! (=> (= guard! true) (= (to_int (char_code c)) (bv2nat (to_char c)))) :pattern ((char_code c)))))
(assert (forall ((a Value)) (! (=> (= guard! true) (is-of_int (char_code a))) :pattern ((char_code a)))))
(assert (forall ((x Value)) (forall ((y Value)) (! (=> (= guard! true) (= (to_int (int_max x y)) (ite (>= (to_int x) (to_int y)) (to_int x) (to_int y)))) :pattern ((int_max x y))))))
(assert (forall ((a Value)) (forall ((b Value)) (! (=> (= guard! true) (is-of_int (int_max a b))) :pattern ((int_max a b))))))
(assert (forall ((x Value)) (forall ((y Value)) (! (=> (= guard! true) (= (to_int (int_min x y)) (ite (>= (to_int y) (to_int x)) (to_int x) (to_int y)))) :pattern ((int_min x y))))))
(assert (forall ((a Value)) (forall ((b Value)) (! (=> (= guard! true) (is-of_int (int_min a b))) :pattern ((int_min a b))))))
(push)
(declare-const x Value)
(assert (is-of_int x))
(declare-const v Value)
(assert (= v x))
(push)
(assert (= guard! true))
(assert (not true))
(check-sat)
(pop)
(push)
(assert (= guard! true))
(assert (not (= (to_bool (of_bool (= v x))) true)))
(check-sat)
(pop)
(pop)
